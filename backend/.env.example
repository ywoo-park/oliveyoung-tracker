# PostgreSQL (Railway 등) — 연결 시 서버 기동 시 `review_analysis_sessions` 테이블이 자동 생성됩니다.
DATABASE_URL=

# 프론트 CORS 허용
FRONTEND_URL=http://localhost:3000

# 선택: Google AI Studio — Gemini 1.5 Flash (기본 분석 모델)
# GEMINI_API_KEY=
# 또는 GOOGLE_API_KEY= (동일)
# 모델 오버라이드 (기본은 코드에서 gemini-2.5-flash → 실패 시 자동 폴백)
# 예: GEMINI_MODEL=gemini-2.5-flash

# 선택: Claude API (레거시·Gemini 실패 시 2차 시도용으로만 사용)
# ANTHROPIC_API_KEY=
# 키가 있어도 무료만 쓰려면 true
# USE_FREE_INSIGHTS_ONLY=true
# CLAUDE_MODEL=claude-sonnet-4-20250514
